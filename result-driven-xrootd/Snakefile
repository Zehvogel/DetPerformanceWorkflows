from pathlib import Path


configfile: "config.yaml"

resource_path = config["resource_path"]

storage:
    provider="xrootd",
    # FIXME: in practice it would be better to remote read the inputs for reco and ntuples to save the disk space
    # but this does not because snakemake wrongly deletes the remote files in this case cf. https://github.com/snakemake/snakemake/issues/3996
    # retrieve=False
    retrieve=True


rule all:
    input:
        [f"<results>/plots/{plot}" for plot in config.get("plot_list", [])]


rule neutral_resolution_plot_E:
    output:
        "<results>/plots/{particle}_{n_events}N/neutral_energy_resolution.pdf"
    input:
        storage.xrootd(expand("root://{resource_path}/ntuples/{particle}_{energy}_cosTheta_{n_events}N.root", energy=config["neutral_resolution_plot_E"]["energies"], allow_missing=True, resource_path=config["resource_path"]))
    # FIXME: there must be a better way to handle this!
    params:
        input_path=lambda wildcards, input: Path(input[0]).parent,
        output_path=lambda wildcards, output: Path(output[0]).parent
    shell:
        """
python plots.py \
    --input_path {params.input_path} \
    --output_path {params.output_path} \
    --particle {wildcards.particle} \
    --energies {config[neutral_resolution_plot_E][energies]} \
    --n_events {wildcards.n_events} \
    --n_bins {config[neutral_resolution_plot_E][n_bins]} \
    --n_threads 1 \
    --batch
        """


rule ntuple:
    output:
        storage.xrootd(f"root://{resource_path}/ntuples/{{particle}}_{{energy}}_cosTheta_{{n_events}}N.root", retrieve=True)
    input:
        storage.xrootd(f"root://{resource_path}/reco/{{particle}}_{{energy}}_cosTheta_{{n_events}}N_REC.edm4hep.root")
    shell:
        f"""
k4run {config["n_tuple_config"]} --inputFiles {{input}} --output {{output}} -n -1
        """


rule reco:
    output:
        storage.xrootd(f"root://{resource_path}/reco/{{particle}}_{{energy}}_cosTheta_{{n_events}}N_REC.edm4hep.root", retrieve=True)
    input:
        storage.xrootd(f"root://{resource_path}/sim/{{particle}}_{{energy}}_cosTheta_{{n_events}}N.edm4hep.root")
    params:
        base_name=lambda wildcards, output: str(Path(output[0]).absolute()).removesuffix("_REC.edm4hep.root"),
        input_absolute=lambda wildcards, input: str(Path(input[0]).absolute())
    shell:
        # FIXME: of course pandora only runs from the one specific directory so need to do a dirty workaround here :(
#         f"""
# k4run {config["reco_config_path"]} --inputFiles {{input}} --outputBasename {{params.base_name}} -n -1
#         """
        """
pushd {config[reco_run_path]}
k4run {config[reco_config_name]} --inputFiles {params.input_absolute} --outputBasename {params.base_name} -n -1
popd
        """


rule sim:
    output:
        storage.xrootd(f"root://{resource_path}/sim/{{particle}}_{{energy}}_cosTheta_{{n_events}}N.edm4hep.root", retrieve=True)
    shell:
        # TODO: make introduce a geometry name to look up the geometry path from a dict and use the geometry name also as a parameter so that it is possible to generate geometry comparison plots with this
        # FIXME: this will need some hash in the temporary file name to avoid collisions when running multiple jobs in parallel :(
        f"""
ddsim --compactFile {config["geometry_path"]} \
      --outputFile {output} \
      --steeringFile {config["steering_path"]} \
      --numberOfEvents {{wildcards.n_events}} \
      --enableGun \
      --gun.particle={{wildcards.particle}} \
      --gun.distribution="cos(theta)"  \
      --gun.energy={{wildcards.energy}}*GeV \
      --crossingAngleBoost=0 \
      --random.seed 1234567890
        """
        # random seed etc. can be made configurable later
